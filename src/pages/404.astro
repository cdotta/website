---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found · Cristian Dotta">
  <main class="mx-auto flex min-h-dvh max-w-[1180px] flex-col items-center justify-center px-6 text-center">
    <div class="eyebrow mb-6">error · 404</div>
    <h1 class="display text-[clamp(48px,10vw,88px)] leading-none text-fg">
      lost the thread<span class="text-mauve">.</span>
    </h1>
    <p class="mt-6 max-w-[420px] text-[16px] leading-[1.6] text-muted">
      This page doesn't exist — or it moved somewhere the router can't follow.
    </p>
    <a href="/" class="btn-solid mt-9">
      back home
      <span class="font-serif text-[16px] italic -translate-y-px">→</span>
    </a>
  </main>
</Layout>
